        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd"> <!-- bean definitions here -->
<!--Beans for first problem-->
    <bean id="e" class="com.cg.bean.Employee">
        <property name="employeeId" value="12345"/>
        <property name="employeeName" value="Harriet"/>
        <property name="salary" value="40000.0"/>
        <property name="businessUnit" value="PES-BU"/>
        <property name="age" value="30"/>
    </bean>
<!--    beans for second and third problem-->
    <context:annotation-config/>
    <bean id="emp1" class="com.cg.bean.Employee">
        <property name="age" value="30"/>
        <property name="employeeId" value="12345"/>
        <property name="employeeName" value="Harriet"/>
        <property name="salary" value="40000.0"/>
    </bean>
    <bean id="emp2" class="com.cg.bean.Employee">
        <property name="age" value="26"/>
        <property name="employeeId" value="12346"/>
        <property name="employeeName" value="Shepherd"/>
        <property name="salary" value="50000.0"/>
    </bean>

    <bean id="sbu" class="com.cg.bean.SBU">
        <constructor-arg name="sBuId" value="PES-BU"/>
        <constructor-arg name="sbuName" value="Product Engineering Services"/>
        <constructor-arg name="sbuHead" value="Kiran Rao"/>
        <property name="empList">
            <list>
                <ref bean="emp1"/>
                <ref bean="emp2"/>
            </list>
        </property>
    </bean>

